# ============================================================
#  ProjectPokedex — .gitignore
#  Place this file in the root of your project:
#  ProjectPokedex/.gitignore
# ============================================================


# ── Java / Spring Boot ────────────────────────────────────────
target/
*.class
*.jar
*.war
*.ear
*.nar
.mvn/wrapper/maven-wrapper.jar
!**/src/main/**/target/
!**/src/test/**/target/

# ── Maven ─────────────────────────────────────────────────────
.mvn/
mvnw
mvnw.cmd

# ── Node / npm ────────────────────────────────────────────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm

# ── Vite / React build output ─────────────────────────────────
dist/
dist-ssr/
*.local

# ── Environment files — never commit secrets ──────────────────
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ── IDE — IntelliJ IDEA ───────────────────────────────────────
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# ── IDE — VS Code ─────────────────────────────────────────────
.vscode/
!.vscode/extensions.json

# ── IDE — Eclipse ─────────────────────────────────────────────
.project
.classpath
.settings/
.factorypath

# ── OS files ──────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Logs ──────────────────────────────────────────────────────
logs/
*.log
spring.log

# ── Database ──────────────────────────────────────────────────
# Ignore snapshot files — these are large and can be regenerated
# Comment this out if you WANT to commit your snapshots
pokemon_snapshot*.sql

# ── Images ────────────────────────────────────────────────────
# Ignore the img folder — too large for git
# Use a shared drive or object storage instead
img/

# ── Misc ──────────────────────────────────────────────────────
*.swp
*.swo
*~
.cache/
.parcel-cache/
